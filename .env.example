APP_ENV=local
APP_NAME=Affiliate-Ai
LOG_LEVEL=INFO

OBSIDIAN_VAULT_PATH=./vault
ENABLE_AUTOPUBLISH=false
ENABLE_AGENT_VOTE=true
MIN_DECISION_SCORE=75

AI_EXECUTION_MODE=codex_cli
CODEX_AUTH_MODE=chatgpt_oauth
ENABLE_CODEX_CLI=true
ENABLE_OPENAI_API_DIRECT=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

MAX_AGENT_RUNS_PER_DAY=10
MAX_CODEX_TASKS_PER_DAY=5

# Multi-channel notification credentials (codex/tasks/007)
LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SHOPEE_COOKIES_PATH=.cookies/shopee.txt
