{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/akeengineer/9ake-kiro-agents/schemas/task.schema.json",
  "title": "Agent Task",
  "description": "Schema for a task dispatched to Claude-CLI or Codex-CLI agents",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "prompt",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique task identifier (UUID)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable task title",
      "minLength": 1,
      "maxLength": 200
    },
    "type": {
      "type": "string",
      "description": "Task type determines which agent handles it",
      "enum": [
        "reasoning",
        "design",
        "review",
        "implementation",
        "test",
        "refactor"
      ]
    },
    "status": {
      "type": "string",
      "description": "Current task status",
      "enum": [
        "queued",
        "active",
        "completed",
        "failed",
        "retrying"
      ]
    },
    "priority": {
      "type": "string",
      "description": "Task priority",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "agent_preference": {
      "type": "string",
      "description": "Preferred agent or auto for dispatcher to decide",
      "enum": [
        "claude",
        "codex",
        "auto"
      ],
      "default": "auto"
    },
    "prompt": {
      "type": "string",
      "description": "The prompt/instruction to send to the agent",
      "minLength": 1
    },
    "dependencies": {
      "type": "array",
      "description": "Task IDs that must complete before this task starts",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      },
      "default": []
    },
    "input_files": {
      "type": "array",
      "description": "Files the agent should read as context",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "expected_outputs": {
      "type": "array",
      "description": "Files or artifacts expected after task completion",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "timeout_seconds": {
      "type": "integer",
      "description": "Max seconds before task is considered timed out",
      "minimum": 30,
      "maximum": 3600,
      "default": 300
    },
    "max_retries": {
      "type": "integer",
      "description": "Max retry attempts before fallback",
      "minimum": 0,
      "maximum": 5,
      "default": 2
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of task creation",
      "format": "date-time"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 timestamp when task started executing",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 timestamp when task completed",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata for the task",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
